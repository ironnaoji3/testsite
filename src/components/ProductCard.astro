---
import type { Product } from '@/types/microcms';

interface Props {
  product: Product;
}

const { product } = Astro.props;
---

<a href={`/products/${product.id}`} class="c-card">
  <div class="c-card__image">
    <img
      src={`${product.thumbnail.url}?w=480&h=270&fit=crop`}
      width="480"
      height="270"
      alt={product.name}
      loading="lazy"
    />
  </div>
  <div class="c-card__body">
    <p class="c-card__category">{product.category.name}</p>
    <p class="c-card__title">{product.name}</p>
    <p class="c-card__excerpt">{product.description}</p>
    {typeof product.price === 'number' && (
      <p class="c-card__price">¥{product.price.toLocaleString('ja-JP')}</p>
    )}
  </div>
</a>
