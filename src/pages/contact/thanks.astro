---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="お問い合わせありがとうございました">
  <section class="p-contact">
    <div class="l-container p-contact__inner">
      <p class="p-contact__lead">
        お問い合わせいただきありがとうございます。<br />
        内容を確認の上、担当者よりご連絡いたします。
      </p>
      <div class="c-actions">
        <a href="/" class="c-button c-button--primary">トップページへ戻る</a>
      </div>
    </div>
  </section>
</BaseLayout>

<!-- GA4等のコンバージョン計測タグを設置する場合はここに追加する -->
